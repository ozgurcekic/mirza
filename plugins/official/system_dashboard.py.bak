import os
import subprocess
import logging
import gi
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, GLib, Gdk, Pango
from plugins.base_plugin import BasePlugin

logger = logging.getLogger(__name__)


class SystemDashboard(BasePlugin):
    """Comprehensive system information and management panel."""

    def __init__(self, mirza=None):
        super().__init__(mirza=mirza)
        self._window = None

    def activate(self):
        super().activate()
        logger.info("SystemDashboard active")

    def open_dashboard(self):
        """Open the dashboard window."""
        if self._window and self._window.get_visible():
            self._window.present()
            return

        self._window = DashboardWindow(mirza=self.mirza)
        self._window.show_all()
        logger.info("Dashboard opened")

    def deactivate(self):
        if self._window:
            self._window.destroy()
        super().deactivate()


class DashboardWindow(Gtk.Window):
    """Main dashboard window with multiple tabs."""

    def __init__(self, mirza=None):
        super().__init__(title="Mîrza - System Dashboard")
        self.mirza = mirza

        self.set_default_size(750, 550)
        self.set_position(Gtk.WindowPosition.CENTER)
        self.set_resizable(True)

        main_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self.add(main_box)

        # Header
        header = Gtk.Box(spacing=10)
        header.set_margin_start(15)
        header.set_margin_end(15)
        header.set_margin_top(15)
        header.set_margin_bottom(10)
        title = Gtk.Label()
        title.set_markup("<b><big>System Dashboard</big></b>")
        title.set_halign(Gtk.Align.START)
        header.pack_start(title, True, True, 0)
        main_box.pack_start(header, False, False, 0)
        main_box.pack_start(Gtk.Separator(), False, False, 0)

        # Notebook
        self.notebook = Gtk.Notebook()
        self.notebook.set_margin_start(10)
        self.notebook.set_margin_end(10)
        self.notebook.set_margin_top(10)

        self._build_device_tab()
        self._build_cleanup_tab()
        self._build_recommendations_tab()

        main_box.pack_start(self.notebook, True, True, 0)
        main_box.pack_start(Gtk.Separator(), False, False, 0)

        # Close button
        btn_box = Gtk.Box(spacing=10)
        btn_box.set_margin_start(15)
        btn_box.set_margin_end(15)
        btn_box.set_margin_top(10)
        btn_box.set_margin_bottom(15)
        btn_box.set_halign(Gtk.Align.END)

        close_btn = Gtk.Button(label="  Close  ")
        close_btn.set_size_request(100, 35)
        close_btn.connect("clicked", lambda w: self.destroy())
        btn_box.pack_start(close_btn, False, False, 0)

        main_box.pack_start(btn_box, False, False, 0)

    # ==================== DEVICE INFO TAB ====================
    def _build_device_tab(self):
        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)

        grid = Gtk.Grid(column_spacing=15, row_spacing=8, margin=15)
        row = 0

        # System info
        self._section(grid, "System Information", row)
        row += 1

        info = self._get_system_info()
        for key, value in info.items():
            self._info_row(grid, key, value, row)
            row += 1

        row += 1
        # Drivers section
        self._section(grid, "Drivers &amp; Kernel Modules", row)
        row += 1

        drivers = self._get_driver_status()
        for driver_name, status in drivers.items():
            self._driver_row(grid, driver_name, status, row)
            row += 1

        scroll.add(grid)
        self.notebook.append_page(scroll, Gtk.Label(label="  Device Info  "))

    def _section(self, grid, text, row):
        label = Gtk.Label()
        label.set_markup(f"<b>{text}</b>")
        label.set_halign(Gtk.Align.START)
        label.set_margin_top(10)
        grid.attach(label, 0, row, 2, 1)

    def _info_row(self, grid, key, value, row):
        label = Gtk.Label(label=key)
        label.set_halign(Gtk.Align.START)
        label.set_margin_start(15)
        grid.attach(label, 0, row, 1, 1)

        val_label = Gtk.Label(label=str(value))
        val_label.set_halign(Gtk.Align.START)
        val_label.set_selectable(True)
        grid.attach(val_label, 1, row, 1, 1)

    def _driver_row(self, grid, name, status, row):
        label = Gtk.Label(label=name)
        label.set_halign(Gtk.Align.START)
        label.set_margin_start(15)
        grid.attach(label, 0, row, 1, 1)

        status_box = Gtk.Box(spacing=10)

        if status["installed"]:
            status_label = Gtk.Label(label="✅ Installed")
        elif status["available"]:
            status_label = Gtk.Label(label="⚠️ Not installed")
            install_btn = Gtk.Button(label="Install")
            install_btn.set_size_request(80, 25)
            install_btn.connect("clicked", self._install_package, status.get("package", name))
            status_box.pack_start(install_btn, False, False, 0)
        else:
            status_label = Gtk.Label(label="❌ Not available")

        status_box.pack_start(status_label, False, False, 0)
        grid.attach(status_box, 1, row, 1, 1)

    def _install_package(self, widget, package_name):
        """Install a package with cross-distro support and error cleanup."""
        pm = self._detect_package_manager()
        if not pm:
            self._show_info("No supported package manager found.\n\nSupported: apt, dnf, pacman, zypper, apk")
            return

        # Build command (pkexec will ask for password with its own GUI dialog) based on package manager
        cmd = []
        cleanup_cmd = []
        try:
            if pm == "apt":
                cmd = ["pkexec", "apt", "install", "-y", "-qq", package_name]
                cleanup_cmd = ["pkexec", "apt", "autoremove", "-y", "-qq"]
            elif pm == "dnf":
                cmd = ["pkexec", "dnf", "install", "-y", "-q", package_name]
                cleanup_cmd = ["pkexec", "dnf", "autoremove", "-y", "-q"]
            elif pm == "pacman":
                cmd = ["pkexec", "pacman", "-S", "--noconfirm", "--needed", package_name]
            elif pm == "zypper":
                cmd = ["pkexec", "zypper", "--non-interactive", "install", package_name]
            elif pm == "apk":
                cmd = ["pkexec", "apk", "add", package_name]

            if not cmd:
                self._show_info(f"Cannot build install command for {pm}")
                return

            result = subprocess.run(cmd, capture_output=True, text=True, timeout=600)

            if result.returncode == 0:
                self._show_info(f"{package_name} installed successfully!")
                # Refresh the recommendations tab
                self._refresh_recommendations()
                # Run cleanup if available
                if cleanup_cmd:
                    subprocess.Popen(cleanup_cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            else:
                error_msg = result.stderr[-200:] if result.stderr else "Unknown error"
                self._show_info(f"Installation failed:\n\n{error_msg}")
                # Clean partial install
                if pm == "apt":
                    subprocess.run(["sudo", "apt", "autoremove", "-y", "-qq"], capture_output=True)
        except subprocess.TimeoutExpired:
            self._show_info("Installation timed out (5 minutes).\nCheck your internet connection.")
        except Exception as e:
            self._show_info(f"Installation error:\n\n{e}")

    def _get_system_info(self):
        """Collect system information."""
        info = {}

        # OS
        try:
            with open("/etc/os-release") as f:
                for line in f:
                    if line.startswith("PRETTY_NAME="):
                        info["OS"] = line.split("=")[1].strip().strip('"')
        except:
            info["OS"] = "Unknown"

        # Kernel
        try:
            result = subprocess.run(["uname", "-r"], capture_output=True, text=True)
            info["Kernel"] = result.stdout.strip()
        except:
            info["Kernel"] = "Unknown"

        # CPU
        try:
            with open("/proc/cpuinfo") as f:
                for line in f:
                    if "model name" in line:
                        info["CPU"] = line.split(":")[1].strip()
                        break
        except:
            info["CPU"] = "Unknown"

        # RAM
        try:
            import psutil
            ram = psutil.virtual_memory()
            info["RAM"] = f"{ram.total / (1024**3):.1f} GB"
        except:
            info["RAM"] = "Unknown"

        # GPU
        try:
            result = subprocess.run(["lspci"], capture_output=True, text=True)
            for line in result.stdout.split("\n"):
                if "VGA" in line or "3D" in line:
                    info["GPU"] = line.split(":")[-1].strip()
                    break
        except:
            info["GPU"] = "Unknown"

        # Display
        info["Session"] = os.environ.get("XDG_SESSION_TYPE", "unknown")
        info["Desktop"] = os.environ.get("XDG_CURRENT_DESKTOP", "unknown")

        return info

    def _get_driver_status(self):
        drivers = {}
        drivers["NVIDIA Driver"] = {
            "installed": self._is_installed("nvidia-driver-550"),
            "available": True,
            "package": "nvidia-driver-550"
        }
        drivers["Intel VA-API"] = {
            "installed": self._is_installed("intel-media-va-driver"),
            "available": True,
            "package": "intel-media-va-driver"
        }
        drivers["CUPS (Printing)"] = {
            "installed": self._is_installed("cups"),
            "available": True,
            "package": "cups"
        }
        return drivers

    # ==================== CLEANUP TAB ====================
    def _build_cleanup_tab(self):
        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)

        grid = Gtk.Grid(column_spacing=15, row_spacing=10, margin=15)
        row = 0

        self._section(grid, "System Cleanup", row)
        row += 1

        info = Gtk.Label()
        info.set_markup("<i>Remove temporary files, package caches, and old logs to free disk space.</i>")
        info.set_halign(Gtk.Align.START)
        info.set_line_wrap(True)
        grid.attach(info, 0, row, 2, 1)
        row += 1

        # Cleanup items
        cleanup_items = [
            ("APT Cache", "pkexec apt clean", "Cleans downloaded package files"),
            ("Journal Logs (7 days)", "pkexec journalctl --vacuum-time=7d", "Removes old system logs"),
            ("Thumbnail Cache", "rm -rf ~/.cache/thumbnails/*", "Deletes cached thumbnails"),
            ("Trash", "rm -rf ~/.local/share/Trash/*", "Empties the trash"),
            ("pip Cache", "pip cache purge", "Cleans Python package cache"),
            ("npm Cache", "npm cache clean --force", "Cleans Node.js package cache"),
            ("Docker (unused)", "docker system prune -f", "Removes unused Docker data"),
        ]

        for item_name, command, description in cleanup_items:
            box = Gtk.Box(spacing=10)
            box.set_margin_start(15)

            label = Gtk.Label(label=f"{item_name}:")
            label.set_halign(Gtk.Align.START)
            label.set_size_request(150, 25)
            box.pack_start(label, False, False, 0)

            desc_label = Gtk.Label(label=description)
            desc_label.set_halign(Gtk.Align.START)
            desc_label.set_size_request(300, 25)
            box.pack_start(desc_label, False, False, 0)

            btn = Gtk.Button(label="Clean")
            btn.set_size_request(80, 25)
            btn.connect("clicked", self._run_cleanup, command, item_name)
            box.pack_start(btn, False, False, 0)

            grid.attach(box, 0, row, 2, 1)
            row += 1

        row += 1
        # Clean all button
        clean_all_btn = Gtk.Button(label="  Clean All  ")
        clean_all_btn.set_size_request(150, 40)
        clean_all_btn.connect("clicked", self._clean_all)
        grid.attach(clean_all_btn, 0, row, 2, 1)

        scroll.add(grid)
        self.notebook.append_page(scroll, Gtk.Label(label="  Cleanup  "))

    def _run_cleanup(self, widget, command, item_name):
        dialog = Gtk.MessageDialog(
            self, 0, Gtk.MessageType.QUESTION, Gtk.ButtonsType.OK_CANCEL,
            f"Run: {item_name}?\n\nCommand: {command}"
        )
        response = dialog.run()
        dialog.destroy()

        if response == Gtk.ResponseType.OK:
            try:
                subprocess.Popen(command, shell=True)
                self._show_info(f"{item_name} completed.")
            except Exception as e:
                self._show_info(f"Failed: {e}")

    def _clean_all(self, widget):
        dialog = Gtk.MessageDialog(
            self, 0, Gtk.MessageType.WARNING, Gtk.ButtonsType.OK_CANCEL,
            "Clean ALL temporary files and caches?\n\nThis may take a few minutes."
        )
        response = dialog.run()
        dialog.destroy()

        if response == Gtk.ResponseType.OK:
            commands = [
                "pkexec apt clean",
                "pkexec journalctl --vacuum-time=7d",
                "rm -rf ~/.cache/thumbnails/*",
                "rm -rf ~/.local/share/Trash/*",
                "pip cache purge",
            ]
            for cmd in commands:
                try:
                    subprocess.Popen(cmd, shell=True)
                except:
                    pass
            self._show_info("Cleanup started in background.")

    # ==================== RECOMMENDATIONS TAB ====================
    def _build_recommendations_tab(self):
        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)

        main_grid = Gtk.Grid(column_spacing=15, row_spacing=10, margin=15)
        row = 0

        self._section(main_grid, "Recommended Software", row)
        row += 1

        # Categories
        categories = {
            "Graphics &amp; Design": {
                "apps": [
                    {"name": "GIMP", "package": "gimp", "desc": "Image editor"},
                    {"name": "Inkscape", "package": "inkscape", "desc": "Vector graphics"},
                    {"name": "Krita", "package": "krita", "desc": "Digital painting"},
                    {"name": "Blender", "package": "blender", "desc": "3D creation suite"},
                    {"name": "Darktable", "package": "darktable", "desc": "RAW photo editor"},
                ],
                "extras": "For color calibration: Install 'gnome-color-manager' or 'displaycal'."
            },
            "Office &amp; Productivity": {
                "apps": [
                    {"name": "LibreOffice", "package": "libreoffice", "desc": "Office suite"},
                    {"name": "Thunderbird", "package": "thunderbird", "desc": "Email client"},
                    {"name": "Zotero", "package": "zotero", "desc": "Reference manager"},
                    {"name": "Joplin", "package": "joplin", "desc": "Note taking"},
                ],
                "extras": "For PDF editing: Install 'scribus' or 'xournalpp'."
            },
            "Development": {
                "apps": [
                    {"name": "VS Code", "package": "code", "desc": "Code editor"},
                    {"name": "Git", "package": "git", "desc": "Version control"},
                    {"name": "Docker", "package": "docker.io", "desc": "Containers"},
                    {"name": "Node.js", "package": "nodejs", "desc": "JavaScript runtime"},
                ],
                "extras": "For databases: Install 'sqlite3', 'postgresql', or 'mysql-server'."
            },
            "Gaming": {
                "apps": [
                    {"name": "Steam", "package": "steam", "desc": "Game platform"},
                    {"name": "Lutris", "package": "lutris", "desc": "Game manager"},
                    {"name": "MangoHud", "package": "mangohud", "desc": "Performance overlay"},
                    {"name": "GameMode", "package": "gamemode", "desc": "Gaming optimizations"},
                ],
                "extras": "For emulators: Install 'retroarch' or 'dolphin-emu'."
            },
        }

        self._app_checkboxes = {}

        for cat_name, cat_data in categories.items():
            # Category header
            cat_label = Gtk.Label()
            cat_label.set_markup(f"<b>{cat_name}</b>")
            cat_label.set_halign(Gtk.Align.START)
            cat_label.set_margin_top(10)
            main_grid.attach(cat_label, 0, row, 2, 1)
            row += 1

            # Apps
            for app in cat_data["apps"]:
                box = Gtk.Box(spacing=10)
                box.set_margin_start(15)

                installed = self._is_installed(app["package"])

                if installed:
                    # Show green checkmark + package name
                    label = Gtk.Label()
                    label.set_markup(f"✅ <b>{app['name']}</b> - {app['desc']} <span foreground='green'>(Installed)</span>")
                    label.set_halign(Gtk.Align.START)
                    box.pack_start(label, False, False, 0)
                else:
                    # Show checkbox + install button
                    cb = Gtk.CheckButton(label=f"{app['name']} - {app['desc']}")
                    cb.set_active(False)
                    self._app_checkboxes[app["package"]] = cb
                    box.pack_start(cb, False, False, 0)

                    install_btn = Gtk.Button(label="Install")
                    install_btn.set_size_request(70, 25)
                    install_btn.connect("clicked", self._install_package, app["package"])
                    box.pack_start(install_btn, False, False, 0)

                main_grid.attach(box, 0, row, 2, 1)
                row += 1

            # Extras tip
            if cat_data.get("extras"):
                tip = Gtk.Label()
                tip.set_markup(f"<i>💡 {cat_data['extras']}</i>")
                tip.set_halign(Gtk.Align.START)
                tip.set_margin_start(15)
                tip.set_line_wrap(True)
                main_grid.attach(tip, 0, row, 2, 1)
                row += 1

        scroll.add(main_grid)
        self.notebook.append_page(scroll, Gtk.Label(label="  Recommendations  "))

    def _detect_package_manager(self):
        """Detect the system package manager."""
        for pm, path in [("apt", "/usr/bin/apt"), ("dnf", "/usr/bin/dnf"),
                          ("pacman", "/usr/bin/pacman"), ("zypper", "/usr/bin/zypper"),
                          ("apk", "/sbin/apk")]:
            if os.path.exists(path):
                return pm
        return None

    def _is_installed(self, package):
        import subprocess
        try:
            r = subprocess.run(["dpkg", "-s", package], capture_output=True, text=True)
            return r.returncode == 0 and "Status: install ok installed" in r.stdout
        except:
            return False

    def _refresh_recommendations(self):
        """Rebuild the recommendations tab after install."""
        # Remove old tab and rebuild
        for i in range(self.notebook.get_n_pages()):
            if self.notebook.get_tab_label_text(self.notebook.get_nth_page(i)) == "  Recommendations  ":
                self.notebook.remove_page(i)
                break
        self._build_recommendations_tab()

    def _show_info(self, message):
        dialog = Gtk.MessageDialog(
            self, 0, Gtk.MessageType.INFO, Gtk.ButtonsType.OK, message
        )
        dialog.run()
        dialog.destroy()
